# ── Required ─────────────────────────────────────────────────
# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# ── Access Control ───────────────────────────────────────────
# Restrict to specific Telegram user IDs (JSON array)
# Empty list [] = allow everyone
ALLOWED_USER_IDS=[325222201]

# ── Database ─────────────────────────────────────────────────
# Defaults work with docker-compose (PostgreSQL)
# For local dev with SQLite, uncomment these:
# DATABASE_URL=sqlite+aiosqlite:///./portfolio.db
# DATABASE_URL_SYNC=sqlite:///./portfolio.db

# Custom PostgreSQL credentials (used by docker-compose.prod.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=portfolio

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Exchange Rates ───────────────────────────────────────────
# Free APIs, no keys needed. Defaults work out of the box.
# FIAT_RATE_API_URL=https://api.exchangerate-api.com/v4/latest
# COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Cache TTLs in seconds (fiat=1h, crypto=5min)
# FIAT_CACHE_TTL=3600
# CRYPTO_CACHE_TTL=300
